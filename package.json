  "license": "MIT",
  "devDependencies": {
    "coveralls": "^3.1.1",
    "cross-env": "^10.1.0",
    "jest": "^30.2.0",
    "jest-junit": "^16.0.0",
    "nyc": "^17.1.0"
  },
