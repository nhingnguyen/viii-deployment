{
  "name": "software-testing-assignment",
  "version": "1.0.0",
  "description": "This is a project template for students participating in Software Testing course\r at LAB University of Applied Sciences.",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --coverage --coverageDirectory=coverage --coverageReporters=lcov",
    "test:ci": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --coverage --ci --reporters=default --reporters=jest-junit"
  },
